import linopy


prices_raw = pd.read_csv(r"C:\Users\don donson\Documents\Uni\OR\Day-ahead_prices_final.csv", encoding="latin1")
pv_raw = pd.read_csv(r"C:\Users\don donson\Documents\Uni\OR\CapacityValues.csv", encoding="latin1", sep=",")


# Define the period you want to analyze
YEARS = [2018, 2019, 2020, 2021, 2022, 2023, 2024]  # 7 years
LOCATIONS = ["Stuttgart", "Duesseldorf", "Schleswig-Holstein"]


pv_raw["time"] = pd.to_datetime(pv_raw["time"], utc=True)
pv_raw["year"] = pv_raw["time"].dt.year


