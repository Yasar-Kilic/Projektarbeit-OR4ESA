def plot_results(summary_df: pd.DataFrame, indicators_df: pd.DataFrame) -> None:
    """Create basic plots for report and presentation."""
    main_df = summary_df[summary_df["scenario"].isin([s["scenario"] for s in MAIN_SCENARIOS])].copy()

    if not main_df.empty:
        # Average annual profit by scenario and location
        pivot_profit = main_df.pivot(index="location", columns="scenario", values="average_annual_profit_EUR")
        ax = pivot_profit.plot(kind="bar", figsize=(10, 5))
        ax.set_ylabel("Average annual profit [€]")
        ax.set_xlabel("Location")
        ax.set_title("Average annual profit by location and scenario")
        plt.tight_layout()
        plt.savefig(FIGURES_DIR / "average_annual_profit_by_location_scenario.png", dpi=300)
        plt.close()

        # PV capacity by scenario and location
        pivot_pv = main_df.pivot(index="location", columns="scenario", values="pv_capacity_kW")
        ax = pivot_pv.plot(kind="bar", figsize=(10, 5))
        ax.set_ylabel("PV capacity [kW]")
        ax.set_xlabel("Location")
        ax.set_title("Optimal PV capacity by location and scenario")
        plt.tight_layout()
        plt.savefig(FIGURES_DIR / "pv_capacity_by_location_scenario.png", dpi=300)
        plt.close()

        # Battery energy capacity by scenario and location
        pivot_bat_e = main_df.pivot(index="location", columns="scenario", values="battery_energy_kWh")
        ax = pivot_bat_e.plot(kind="bar", figsize=(10, 5))
        ax.set_ylabel("Battery energy capacity [kWh]")
        ax.set_xlabel("Location")
        ax.set_title("Optimal battery energy capacity by location and scenario")
        plt.tight_layout()
        plt.savefig(FIGURES_DIR / "battery_energy_capacity_by_location_scenario.png", dpi=300)
        plt.close()

        # Battery power capacity by scenario and location
        pivot_bat_p = main_df.pivot(index="location", columns="scenario", values="battery_power_kW")
        ax = pivot_bat_p.plot(kind="bar", figsize=(10, 5))
        ax.set_ylabel("Battery power capacity [kW]")
        ax.set_xlabel("Location")
        ax.set_title("Optimal battery power capacity by location and scenario")
        plt.tight_layout()
        plt.savefig(FIGURES_DIR / "battery_power_capacity_by_location_scenario.png", dpi=300)
        plt.close()

    sens_df = summary_df[summary_df["scenario"] == "battery_cost_sensitivity_sell_only"].copy()
    if not sens_df.empty:
        for location in sorted(sens_df["location"].unique()):
            loc_df = sens_df[sens_df["location"] == location].sort_values("battery_cost_factor")

            ax = loc_df.plot(x="battery_cost_factor", y="battery_energy_kWh", marker="o", figsize=(8, 5), legend=False)
            ax.set_xlabel("Battery cost factor")
            ax.set_ylabel("Battery energy capacity [kWh]")
            ax.set_title(f"Battery energy capacity under cost sensitivity – {location}")
            plt.tight_layout()
            plt.savefig(FIGURES_DIR / f"battery_energy_sensitivity_{location}.png", dpi=300)
            plt.close()

            ax = loc_df.plot(x="battery_cost_factor", y="average_annual_profit_EUR", marker="o", figsize=(8, 5), legend=False)
            ax.set_xlabel("Battery cost factor")
            ax.set_ylabel("Average annual profit [€]")
            ax.set_title(f"Profit under battery cost sensitivity – {location}")
            plt.tight_layout()
            plt.savefig(FIGURES_DIR / f"profit_sensitivity_{location}.png", dpi=300)
            plt.close()

    if not indicators_df.empty:
        # Market indicators table is saved as CSV; this scatter helps interpret battery profitability.
        merged = pd.merge(
            main_df,
            indicators_df[["location", "scenario", "avg_daily_spread_EUR_per_MWh"]],
            on=["location", "scenario"],
            how="left",
        )
        if not merged.empty:
            ax = merged.plot(
                x="avg_daily_spread_EUR_per_MWh",
                y="average_annual_profit_EUR",
                kind="scatter",
                figsize=(8, 5),
            )
            ax.set_xlabel("Average daily price spread [€/MWh]")
            ax.set_ylabel("Average annual profit [€]")
            ax.set_title("Profit and average daily price spread")
            plt.tight_layout()
            plt.savefig(FIGURES_DIR / "profit_vs_daily_price_spread.png", dpi=300)
            plt.close()


def plot_example_dispatch(timeseries: pd.DataFrame) -> None:
    """Plot dispatch for a representative week."""
    ts = timeseries.copy()
    ts["time"] = pd.to_datetime(ts["time"], utc=True)
    ts = ts.set_index("time")

    # Choose a week with meaningful PV output. Change the dates if needed.
    week = ts.loc["2024-06-01":"2024-06-07"].copy()
    if week.empty:
        week = ts.iloc[:168].copy()

    ax = week[["g_pv_kWh", "q_sell_kWh", "charge_kWh", "discharge_kWh"]].plot(figsize=(12, 5))
    ax.set_ylabel("Energy per hour [kWh]")
    ax.set_xlabel("Time")
    ax.set_title("Example dispatch week")
    plt.tight_layout()
    plt.savefig(FIGURES_DIR / "example_dispatch_week.png", dpi=300)
    plt.close()

    ax = week[["soc_kWh"]].plot(figsize=(12, 5), legend=False)
