def prepare_multiyear_data(years, location):
    #Prepare data for multiple years, trimming to 8760 hours per year
    all_data = []
    
    for year in years:
        pv_scenario = pv_raw[pv_raw["year"] == year].copy()
        price_scenario = prices_raw[str(year)].copy()
        
        # Trim both to 8760 hours (remove leap days)
        pv_scenario = pv_scenario.iloc[:8760].copy()
        price_scenario = price_scenario.iloc[:8760].copy()
        
        data = pd.DataFrame({
            "time": pv_scenario["time"].values,
            "price": price_scenario.values / 1000.0,  # €/MWh to €/kWh
            "pv_cf": pv_scenario[location].values,
            "year": year
        })
        
        all_data.append(data)
    
    # Concatenate all years
    multiyear_data = pd.concat(all_data, ignore_index=True)
    
    multiyear_data = multiyear_data.set_index("time")
    multiyear_data.index.name = "time"
    
    print(f"Total hours: {len(multiyear_data)}")
    print(f"Expected (8760 × {len(years)}): {8760 * len(years)}")
    
    return multiyear_data


def run_multiyear_model(years, location):
    # Prepare multi-year data
    data = prepare_multiyear_data(years, location)
    
    time = data.index
    time.name = "time"
    
    price = xr.DataArray(
        data["price"].values,
        coords={"time": time},
        dims=["time"]
    )
    
    pv_cf = xr.DataArray(
        data["pv_cf"].values,
        coords={"time": time},
        dims=["time"]
    )
    
    # Technical & economic parameters 
    E_unit = 1000.0   # kWh per unit (1 MWh)
    P_unit = 900.0    # kW per unit (0.9 MW)
    
    bat_inv_cost_per_kWh = 390.0  # €/kWh
    bat_inv_cost_per_unit = bat_inv_cost_per_kWh * E_unit  # €/unit
    
    pv_inv_cost = 800.0  # €/kW
    
    # Lifetime and annualized costs
    lifetime_pv = 25      # years
    lifetime_bat = 12     # years
    years_count = len(years)
    
    pv_inv_cost_annual = pv_inv_cost / lifetime_pv
    bat_inv_cost_annual = bat_inv_cost_per_unit / lifetime_bat
    
    eta_charge = 0.95
    eta_discharge = 0.95
    dt = 1.0  # 1 hour
    
    # Create the optimization model
    m = linopy.Model()
    
    # Capacity variables 
    C_pv = m.add_variables(lower=0, name="C_pv")
    N_bat = m.add_variables(lower=0, name="N_bat")
    
    # Time-dependent variables
    g_pv = m.add_variables(lower=0, dims=["time"], coords={"time": time}, name="g_pv")
    charge = m.add_variables(lower=0, dims=["time"], coords={"time": time}, name="charge")
    discharge = m.add_variables(lower=0, dims=["time"], coords={"time": time}, name="discharge")
    soc = m.add_variables(lower=0, dims=["time"], coords={"time": time}, name="soc")
    q_sell = m.add_variables(lower=0, dims=["time"], coords={"time": time}, name="q_sell")
    
    # Constraints
    
    # PV generation limit
    m.add_constraints(g_pv <= C_pv * pv_cf, name="pv_capacity_limit")
    
    # Battery power limits
    m.add_constraints(charge <= N_bat * P_unit, name="charge_power_limit")
    m.add_constraints(discharge <= N_bat * P_unit, name="discharge_power_limit")
    
    # Battery energy capacity
    m.add_constraints(soc <= N_bat * E_unit, name="soc_energy_limit")
    
    # Budget constraint (using CAPEX, not annualized)
    budget = 10_000_000.0  # Total budget in €
    m.add_constraints(
        pv_inv_cost * C_pv + bat_inv_cost_per_unit * N_bat <= budget,
        name="budget_limit"
    )
    
    # Battery dynamics (continuous across all years)
    m.add_constraints(
        soc == soc.shift(time=1) + eta_charge * charge * dt - discharge * dt / eta_discharge,
        name="soc_dynamics"
    )
    
    # Initial SoC = 0
    m.add_constraints(soc.sel(time=time[0]) == 0, name="soc_initial")
    
    # Energy balance
    m.add_constraints(g_pv + discharge == q_sell + charge, name="energy_balance")
    
    # Objective: maximize profit (total revenue - total annualized costs)
    # Total revenue over all years
    total_revenue = (price * q_sell * dt).sum()
    
    # Total annualized costs over 7 years
    total_costs = (
        pv_inv_cost_annual * C_pv * years_count
        + bat_inv_cost_annual * N_bat * years_count
    )
    
    # Objective: Total Revenue - Total Annualized Costs
    m.add_objective(total_revenue - total_costs, sense="max")
    
    # === SOLVE ===
    result = m.solve()
    
    return {
        "model": m,
        "result": result,
        "C_pv": C_pv,
        "N_bat": N_bat,
        "g_pv": g_pv,
        "charge": charge,
        "discharge": discharge,
        "soc": soc,
        "q_sell": q_sell,
        "price": price,
        "pv_cf": pv_cf,
        "years": years,
        "budget": budget,
    }


if __name__ == "__main__":
    # Test with 2018-2024 (7 years, includes energy crisis prices)
    years = YEARS  # Use the YEARS defined at top
    res = run_multiyear_model(years, "Stuttgart")
    
    print(f"\n{'='*60}") # Print a separator line by repeating '=' 60 times
    print(f"Results for {years[0]}-{years[-1]} ({len(years)} years)")
    print(f"{'='*60}")
    print("Solver status:", res["result"])
    print("Optimal PV capacity [kW]:", res["C_pv"].solution.values) # show optimal PV capacity
    print("Optimal battery units [-]:", res["N_bat"].solution.values) # show optimal battery units
    print("Total profit (NPV) [€]:", res["model"].objective.value)  # show total profit (NPV) over all years
    
    # Calculate used CAPEX (investment cost, not annualized) 
    used_capex = (
        800.0 * res["C_pv"].solution.values
        + 390.0 * 1000.0 * res["N_bat"].solution.values
    )
    print(f"Used CAPEX [€]: {used_capex:.2f}")
    print(f"Budget [€]: {res['budget']:.2f}") # show budget
    
    # Calculate annualized return
    npv = res["model"].objective.value
    years_count = len(years)
    annualized_npv = npv / years_count
    print(f"Average annual profit [€]: {annualized_npv:.2f}")
    print(f"Return [%]: {(annualized_npv / used_capex) * 100:.2f}%")
    # Payback period
    annual_revenue = (res['price'].values.mean() * res['pv_cf'].values.mean() * 8760 * res["C_pv"].solution.values)
    payback = used_capex / annual_revenue
    print(f"Payback period: {payback:.2f} years")
